<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.customers.mapper.TraceabilityNodeMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.customers.entity.TraceabilityNode">
        <id column="id" property="id"/>
        <result column="product_batch_no" property="productBatchNo"/>
        <result column="node_name" property="nodeName"/>
        <result column="node_description" property="nodeDescription"/>
        <result column="node_time" property="nodeTime"/>
        <result column="location" property="location"/>
        <result column="operator" property="operator"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectByProductBatchNo" resultMap="BaseResultMap">
        SELECT * FROM traceability_node
        WHERE product_batch_no = #{batchNo}
          AND deleted = 0
        ORDER BY sort_order ASC
    </select>

    <select id="selectByNodeName" resultMap="BaseResultMap">
        SELECT * FROM traceability_node
        WHERE node_name LIKE CONCAT('%', #{nodeName}, '%')
          AND deleted = 0
        ORDER BY sort_order ASC
    </select>

    <select id="selectByOperator" resultMap="BaseResultMap">
        SELECT * FROM traceability_node
        WHERE operator LIKE CONCAT('%', #{operator}, '%')
          AND deleted = 0
        ORDER BY node_time DESC
    </select>

</mapper>
