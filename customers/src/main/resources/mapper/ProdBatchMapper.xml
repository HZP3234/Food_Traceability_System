<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.customers.mapper.ProdBatchMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.customers.entity.ProdBatch">
        <id column="prod_batch_id" property="prodBatchId"/>
        <result column="batch_no" property="batchNo"/>
        <result column="product_name" property="productName"/>
        <result column="process_batch_no" property="processBatchNo"/>
        <result column="production_line" property="productionLine"/>
        <result column="planned_amount" property="plannedAmount"/>
        <result column="actual_amount" property="actualAmount"/>
        <result column="production_date" property="productionDate"/>
        <result column="check_result" property="checkResult"/>
        <result column="code_status" property="codeStatus"/>
        <result column="batch_status" property="batchStatus"/>
        <result column="data_hash" property="dataHash"/>
        <result column="chain_hash" property="chainHash"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByBatchNo" resultMap="BaseResultMap">
        SELECT * FROM t_prod_batch
        WHERE batch_no = #{batchNo}
          AND is_deleted = 0
        LIMIT 1
    </select>

</mapper>
