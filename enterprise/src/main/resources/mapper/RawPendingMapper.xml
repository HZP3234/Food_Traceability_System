<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.RawPendingMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.RawPending">
        <id column="raw_pending_id" property="rawPendingId"/>
        <result column="pending_code" property="pendingCode"/>
        <result column="product_name" property="productName"/>
        <result column="product_category" property="productCategory"/>
        <result column="supplier_name" property="supplierName"/>
        <result column="amount" property="amount"/>
        <result column="raw_detail_id" property="rawDetailId"/>
        <result column="matched_batch_no" property="matchedBatchNo"/>
        <result column="pending_status" property="pendingStatus"/>
        <result column="upload_time" property="uploadTime"/>
        <result column="match_time" property="matchTime"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByPendingCode" resultMap="BaseResultMap">
        SELECT * FROM t_raw_pending WHERE pending_code = #{pendingCode} AND is_deleted = 0 LIMIT 1
    </select>

    <select id="selectByPendingStatus" resultMap="BaseResultMap">
        SELECT * FROM t_raw_pending WHERE pending_status = #{pendingStatus} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectBySupplierName" resultMap="BaseResultMap">
        SELECT * FROM t_raw_pending WHERE supplier_name LIKE CONCAT('%', #{supplierName}, '%') AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>