<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.SalesTerminalMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.SalesTerminal">
        <id column="terminal_id" property="terminalId"/>
        <result column="terminal_code" property="terminalCode"/>
        <result column="terminal_name" property="terminalName"/>
        <result column="terminal_type" property="terminalType"/>
        <result column="area" property="area"/>
        <result column="address" property="address"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operator_name" property="operatorName"/>
        <result column="terminal_status" property="terminalStatus"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByTerminalCode" resultMap="BaseResultMap">
        SELECT * FROM t_sales_terminal WHERE terminal_code = #{code} AND is_deleted = 0 LIMIT 1
    </select>

    <select id="selectByOperatorId" resultMap="BaseResultMap">
        SELECT * FROM t_sales_terminal WHERE operator_id = #{operatorId} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByArea" resultMap="BaseResultMap">
        SELECT * FROM t_sales_terminal WHERE area LIKE CONCAT('%', #{area}, '%') AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByTerminalStatus" resultMap="BaseResultMap">
        SELECT * FROM t_sales_terminal WHERE terminal_status = #{status} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>