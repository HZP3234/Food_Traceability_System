<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.SalesStockMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.SalesStock">
        <id column="stock_id" property="stockId"/>
        <result column="stock_code" property="stockCode"/>
        <result column="terminal_id" property="terminalId"/>
        <result column="terminal_name" property="terminalName"/>
        <result column="prod_batch_id" property="prodBatchId"/>
        <result column="prod_batch_no" property="prodBatchNo"/>
        <result column="product_name" property="productName"/>
        <result column="quantity" property="quantity"/>
        <result column="received_time" property="receivedTime"/>
        <result column="last_check_time" property="lastCheckTime"/>
        <result column="stock_status" property="stockStatus"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByTerminalId" resultMap="BaseResultMap">
        SELECT * FROM t_sales_stock WHERE terminal_id = #{terminalId} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByProdBatchNo" resultMap="BaseResultMap">
        SELECT * FROM t_sales_stock WHERE prod_batch_no = #{batchNo} AND is_deleted = 0
    </select>

    <select id="selectByStockStatus" resultMap="BaseResultMap">
        SELECT * FROM t_sales_stock WHERE stock_status = #{status} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>