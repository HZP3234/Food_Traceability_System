<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.CcVehicleMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.CcVehicle">
        <id column="vehicle_id" property="vehicleId"/>
        <result column="plate_no" property="plateNo"/>
        <result column="vehicle_model" property="vehicleModel"/>
        <result column="driver_name" property="driverName"/>
        <result column="driver_phone" property="driverPhone"/>
        <result column="owner_id" property="ownerId"/>
        <result column="owner_name" property="ownerName"/>
        <result column="cold_type" property="coldType"/>
        <result column="temp_range" property="tempRange"/>
        <result column="vehicle_status" property="vehicleStatus"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByPlateNo" resultMap="BaseResultMap">
        SELECT * FROM t_cc_vehicle WHERE plate_no = #{plateNo} AND is_deleted = 0 LIMIT 1
    </select>

    <select id="selectByOwnerId" resultMap="BaseResultMap">
        SELECT * FROM t_cc_vehicle WHERE owner_id = #{ownerId} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByVehicleStatus" resultMap="BaseResultMap">
        SELECT * FROM t_cc_vehicle WHERE vehicle_status = #{status} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByColdType" resultMap="BaseResultMap">
        SELECT * FROM t_cc_vehicle WHERE cold_type = #{coldType} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>