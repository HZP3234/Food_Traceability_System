<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.RawTransportPendingMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.RawTransportPending">
        <id column="id" property="id"/>
        <result column="raw_detail_id" property="rawDetailId"/>
        <result column="raw_batch_no" property="rawBatchNo"/>
        <result column="transport_order_no" property="transportOrderNo"/>
        <result column="supplier_name" property="supplierName"/>
        <result column="match_status" property="matchStatus"/>
        <result column="match_time" property="matchTime"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectBySupplierName" resultMap="BaseResultMap">
        SELECT * FROM t_raw_transport_pending
        WHERE supplier_name = #{supplierName} AND is_deleted = 0
        ORDER BY create_time DESC
    </select>

    <select id="selectByMatchStatus" resultMap="BaseResultMap">
        SELECT * FROM t_raw_transport_pending
        WHERE match_status = #{matchStatus} AND is_deleted = 0
        ORDER BY create_time DESC
    </select>

    <select id="selectByTransportOrderNo" resultMap="BaseResultMap">
        SELECT * FROM t_raw_transport_pending
        WHERE transport_order_no = #{transportOrderNo} AND is_deleted = 0
        ORDER BY create_time DESC
    </select>

</mapper>
