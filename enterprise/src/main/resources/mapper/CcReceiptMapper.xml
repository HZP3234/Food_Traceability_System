<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.CcReceiptMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.CcReceipt">
        <id column="receipt_id" property="receiptId"/>
        <result column="order_no" property="orderNo"/>
        <result column="signer" property="signer"/>
        <result column="sign_time" property="signTime"/>
        <result column="sign_temp" property="signTemp"/>
        <result column="is_package_intact" property="isPackageIntact"/>
        <result column="qty_match" property="qtyMatch"/>
        <result column="qty_mismatch_desc" property="qtyMismatchDesc"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByOrderNo" resultMap="BaseResultMap">
        SELECT * FROM t_cc_receipt WHERE order_no = #{orderNo} AND is_deleted = 0 LIMIT 1
    </select>

</mapper>