<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.RawDetailMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.RawDetail">
        <id column="raw_detail_id" property="rawDetailId"/>
        <result column="batch_no" property="batchNo"/>
        <result column="origin" property="origin"/>
        <result column="farm_type" property="farmType"/>
        <result column="feed_type" property="feedType"/>
        <result column="cert_type" property="certType"/>
        <result column="inspection_no" property="inspectionNo"/>
        <result column="breed" property="breed"/>
        <result column="scale_desc" property="scaleDesc"/>
        <result column="collect_date" property="collectDate"/>
        <result column="uploader" property="uploader"/>
        <result column="upload_time" property="uploadTime"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByBatchNo" resultMap="BaseResultMap">
        SELECT * FROM t_raw_detail WHERE batch_no = #{batchNo} AND is_deleted = 0 LIMIT 1
    </select>

    <select id="selectByOrigin" resultMap="BaseResultMap">
        SELECT * FROM t_raw_detail WHERE origin LIKE CONCAT('%', #{origin}, '%') AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>