<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.enterprise.mapper.TraceCodeBindMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.enterprise.entity.TraceCodeBind">
        <id column="bind_id" property="bindId"/>
        <result column="trace_code" property="traceCode"/>
        <result column="biz_type" property="bizType"/>
        <result column="biz_id" property="bizId"/>
        <result column="biz_no" property="bizNo"/>
        <result column="create_time" property="createTime"/>
        <result column="operator" property="operator"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByTraceCode" resultMap="BaseResultMap">
        SELECT * FROM t_trace_code_bind WHERE trace_code = #{code} AND is_deleted = 0 ORDER BY create_time ASC
    </select>

    <select id="selectByBizType" resultMap="BaseResultMap">
        SELECT * FROM t_trace_code_bind WHERE biz_type = #{bizType} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>