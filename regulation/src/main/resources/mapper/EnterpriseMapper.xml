<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodtraceability.regulation.mapper.EnterpriseMapper">

    <resultMap id="BaseResultMap" type="com.foodtraceability.regulation.entity.Enterprise">
        <id column="enterprise_id" property="enterpriseId"/>
        <result column="enterprise_uuid" property="enterpriseUuid"/>
        <result column="enterprise_name" property="enterpriseName"/>
        <result column="enterprise_type" property="enterpriseType"/>
        <result column="cert_no" property="certNo"/>
        <result column="address" property="address"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="contact_person" property="contactPerson"/>
        <result column="risk_level" property="riskLevel"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectByEnterpriseUuid" resultMap="BaseResultMap">
        SELECT * FROM t_enterprise WHERE enterprise_uuid = #{uuid} AND is_deleted = 0 LIMIT 1
    </select>

    <select id="selectByEnterpriseName" resultMap="BaseResultMap">
        SELECT * FROM t_enterprise WHERE enterprise_name LIKE CONCAT('%', #{name}, '%') AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByRiskLevel" resultMap="BaseResultMap">
        SELECT * FROM t_enterprise WHERE risk_level = #{riskLevel} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByEnterpriseType" resultMap="BaseResultMap">
        SELECT * FROM t_enterprise WHERE enterprise_type = #{type} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>